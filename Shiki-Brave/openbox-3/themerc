!! Original Onyx by Dana Jansens | Mod Onyx-black by AquaFox
!! inspired by "Carbon" by p0ng, and the ever so popular Vista glass look

!! Menu background
menu.items.bg: flat gradient vertical
menu.items.bg.color: #FFFFFF
menu.items.bg.colorTo: #FFFFFF

!! Menu text
menu.items.text.color: #000000
menu.items.justify: justify
menu.items.disabled.text.color: #606060

!! Menu headers
menu.title.bg: raised splitvertical gradient
menu.title.bg.color: #4a90d9
menu.title.bg.colorTo: #4a80d8
menu.title.text.color: #ffffff
menu.title.text.justify: center

!! Selected menu item
menu.items.active.bg: raised splitvertical gradient
menu.items.active.bg.color: #4a90d9
menu.items.active.bg.colorTo: #4a80d8
menu.items.active.text.color: #ffffff

!! Titlebar
window.active.title.bg: flat
window.active.title.bg.color: #EDECEB
window.active.title.bg.colorTo: #EDECEB
window.inactive.title.bg: gradient splitvertical gradient flat
window.inactive.title.bg.color: #4a90d9
window.inactive.title.bg.colorTo: #4a80d8

!! Titlebar text
window.label.text.justify: center
window.active.label.bg: parentrelative
window.active.label.text.color: #000000
window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #747474

!! Window buttons
window.*.button.*.bg: parentrelative
window.active.button.*.hover.bg: flat splitvertical gradient border
window.inactive.button.*.hover.bg: parentrelative
window.*.button.*.pressed.bg: flat splitvertical gradient border

window.active.button.*.hover.bg.color: #DEE0D8
window.active.button.*.hover.bg.colorTo: #E0E0D8
window.active.button.*.hover.bg.border.color: #236d83
window.active.button.*.hover.image.color: #000000

window.active.button.*.pressed.bg.color: #DEE0D8
window.active.button.*.pressed.bg.colorTo: #E0E0D8
window.active.button.*.pressed.image.color: #E0E0D8
window.active.button.*.pressed.bg.border.color: #154350
window.inactive.button.*.pressed.bg.color: #4ab5ff
window.inactive.button.*.pressed.bg.colorTo: #38b3d6
window.inactive.button.*.pressed.image.color: #b7fdef
window.inactive.button.*.pressed.bg.border.color: #38b3d6

window.active.button.*.image.color: #000000
window.inactive.button.*.image.color: #747474

!! Borders
window.active.border.color: #4A90D9
window.inactive.border.color: #181818
window.inactive.title.separator.color: #EDEDED
window.active.title.separator.color: #EDEDED
border.width: 5
padding.width: 2
window.handle.width: 0
window.active.client.color:  #EDECEB
window.inactive.client.color:  #EDECEB
window.client.padding.width: 1
window.client.padding.height: 1
menu.overlap: 0

!! Font shadows
menu.items.font:shadow=n:shadowtint=30

!! On-screen displays
osd.bg: flat
osd.bg.color: #EDECEB
osd.bg.colorTo: #181818
#osd.label.bg: parentrelative
osd.hilight.bg: flat
osd.hilight.bg.color: #4a90d9
osd.hilight.bg.colorTo: #4a80d8
osd.unhilight.bg: raised splitvertical gradient
osd.unhilight.bg.color: #303030
osd.unhilight.bg.colorTo:#181818
osd.label.text.color: #000000
osd.border.color: #000000
