pkgname=gmrun-dark
_realpkgname=gmrun
pkgver=0.9.2
pkgrel=4
pkgdesc="A simple program which provides a run program window"
arch=('i686' 'x86_64')
url="http://sf.net/projects/gmrun"
license=('GPL')
depends=('gtk2' 'popt')
conflicts=('gmrun')
source=(http://downloads.sourceforge.net/$pkgname/$_realpkgname-$pkgver.tar.gz
	gcc43.patch 	 "main.cc")
md5sums=('6cef37a968006d9496fc56a7099c603c'
	 '3a0b69d8c2cac6cfb551b9d235441ecb'
	 '5fe7f6c895ad875da1eb402c88e38ec2')

build() {
	cp -f ./main.cc ${srcdir}/${_realpkgname}-${pkgver}/src
	cd "${srcdir}/${_realpkgname}-${pkgver}"
	patch -p0 -i "$srcdir/gcc43.patch"
	./configure --prefix=/usr
	make
}

package() {
	cd "${srcdir}/${_realpkgname}-${pkgver}"

	make DESTDIR="${pkgdir}" install
} 
